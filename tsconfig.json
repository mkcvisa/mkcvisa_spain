{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": ".vercel/output",
    "rootDir": ".",
    "moduleResolution": "node"
  },
  "include": ["api/**/*", "lib/**/*", "services/**/*"],
  "exclude": ["node_modules", ".vercel"]
}
